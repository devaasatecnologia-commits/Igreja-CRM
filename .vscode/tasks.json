{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Iniciar Backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "📝 Terminal de Desenvolvimento",
      "type": "shell",
      "command": "echo '📝 Terminal pronto para comandos Git e atualizações' && echo '' && echo 'Comandos úteis:' && echo '  git status' && echo '  git add .' && echo '  git commit -m \"mensagem\"' && echo '  git push' && echo '' && echo '📌 Você está em: ${workspaceFolder}' && echo '' && echo '✅ Terminal pronto!'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "🔄 Git Status",
      "type": "shell",
      "command": "git status",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "📤 Git Push",
      "type": "shell",
      "command": "git add . && git commit -m \"Atualização do sistema\" && git push",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "📥 Git Pull",
      "type": "shell",
      "command": "git pull",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
